// FunГ§ГЈo de processamento de mensagens extraГ­da para escopo de mГіdulo
async function handleIncoming(message) {
  // вњ… FIX: Normaliza JID primeiro (converte @lid para @c.us automaticamente)
  let jid = message.from;
  if (jid.endsWith('@lid')) {
    // tenta usar o nГєmero real se estiver disponГ­vel; caso contrГЎrio mantГ©m o @lid
    jid = message.author || message.from;
  }
  jid = normalizarJid(jid);

  logger.log(`[RECEBIDO] ${jid.split('@')[0]} | tipo=${message.type || 'unknown'} | fromMe=${message.fromMe} | grupo=${message.isGroupMsg} | body=${String(message.body || '').substring(0, 100)}`);

  // вњ… FIX: Verifica se Г© grupo ANTES de outras validaГ§Гµes
  if (message.isGroupMsg || jid.endsWith("@g.us") || jid.includes("@status") || jid === "status@broadcast") {
    logger.log(`[IGNORADO] ${jid.split('@')[0]} Г© grupo/status/broadcast`);
    return; // Ignora grupos, status, broadcasts
  }

  // Ignora mensagens prГіprias, exceto se for Admin, Suporte ou Atendente
  if (message.fromMe && !ADMIN_JIDS.has(jid) && !CONTATO_SUPORTE.has(jid) && !ATENDENTE_ATUAL.has(jid)) {
    logger.log(`[IGNORADO] ${jid.split('@')[0]} Г© mensagem prГіpria`);
    return;
  }

  // Ignora contatos explicitamente bloqueados
  if (ignoredContacts.has(jid)) {
    logger.log(`[IGNORADO] blacklist: ${jid.split('@')[0]}`);
    return;
  }

  try {
    const contact = client ? await client.getContactById(jid) : null;
    logger.log(`[CONTATO] ${jid.split('@')[0]} - isMyContact=${contact?.isMyContact}`);
    if (TEST_MODE_IGNORAR_SALVOS && contact && contact.isMyContact && !ADMIN_JIDS.has(jid) && !CONTATO_SUPORTE.has(jid) && !ATENDENTE_ATUAL.has(jid)) {
      logger.log(`[IGNORADO] contato salvo (teste): ${jid.split('@')[0]}`);
      return;
    }
  } catch (e) {
    logger.warn(`вљ пёЏ erro ao obter contato: ${e.message}`);
  }

  const texto = (message.body || '').trim().toLowerCase();
  if (!texto) {
    logger.warn(`[IGNORADO] ${jid.split('@')[0]} enviou mensagem sem texto. Tipo: ${message.type || 'unknown'}`);
    await sendMessage(jid, 'вљ пёЏ Recebi a sua mensagem, mas sГі consigo responder a textos. Por favor, envie uma mensagem de texto ou digite *menu*.');
    return;
  }

  const isStaff = ADMIN_JIDS.has(jid) || CONTATO_SUPORTE.has(jid) || ATENDENTE_ATUAL.has(jid);
  let estado = estados.get(jid) || "menu_principal";

  // CONTROLE DE ATENDIMENTO HUMANO
  if ((clientesPausados.has(jid) || emAtendimentoHumano.has(jid) || clientesEmFila.has(jid)) && !isStaff) {
    logger.log(`[MUDO] ${jid.split('@')[0]} estГЎ em atendimento/fila/pausado`);
    return;   // Bot nГЈo responde nada automaticamente
  }

  if (emAtendimentoHumano.has(jid) && isStaff) {
    if (!texto.startsWith('liberar') && !texto.startsWith('limite') && !texto.startsWith('kpi') && texto !== 'menu' && texto !== 'finalizar') {
      await sendMessage(jid, 'рџ”’ VocГЄ estГЎ em modo atendimento humano. Use comandos: liberar, limite, kpi, menu.');
      return;
    }
  }

  try {
    // ==================== INATIVIDADE ====================
    if (estado === "inativo") {
      if (texto === "1") {
        const currentData = stateData.get(jid) || {};
        const previousState = currentData.previousState || "menu_principal";
        const resumedData = { ...currentData };
        delete resumedData.previousState;
        setState(jid, previousState, resumedData);
        await sendMessage(jid, "вњ… *Continuando de onde vocГЄ parou...*");
        switch (previousState) {
          case "horarios":
            await showHorarios(jid);
            break;
          case "confirmacao_horarios":
            await sendMessage(jid,
              `*ConfirmaГ§ГЈo de HorГЎrios*\n\n` +
              `Modalidade: ${resumedData.modalidade || "NГЈo informada"}\n` +
              `Valor: ${resumedData.valor || "NГЈo informado"}\n\n` +
              `*1 - Seguir para AssistГЄncia*\n` +
              `*0 - Voltar*`
            );
            break;
          case "assistГЄncia": {
            const ctxAssist = stateData.get(jid) || {};
            if (ctxAssist.nome) {
              await sendMessage(jid, `вњ… *Nome jГЎ registrado:* ${ctxAssist.nome}\n\nInforme a *modalidade, plano ou pacote* desejado.\nExemplo: MusculaГ§ГЈo, Pilates, Pacote Completo, etc.`);
            } else {
              await sendMessage(jid, "Por favor, informe seu *nome completo* para continuar.\nExemplo: Maria Oliveira");
            }
            break;
          }
          case "valores": await showValores(jid, resumedData.flow); break;
          case "valores_mensais": await showValoresMensais(jid); break;
          case "valores_diarios": await showValoresDiaria(jid); break;
          case "planos": await showPlanos(jid); break;
          case "pacotes": await showPacotes(jid); break;
          case "modalidades": await showModalidades(jid, resumedData.flow); break;
          case "pass": await showPass(jid); break;
          case "feedback": await showFeedback(jid); break;
          case "informacoes": await showInformacoes(jid); break;
          default: await showMainMenu(jid);
        }
      }
      else if (texto === "0" || texto.toLowerCase() === "menu") {
        await showMainMenu(jid);
      }
      else {
        await sendMessage(jid,
          `вЏі *VocГЄ ficou inativo por muito tempo.*\n\n` +
          `*1 - Continuar de onde parei*\n` +
          `*0 - Voltar ao menu principal*`
        );
      }
      return;
    }

    if (verificarLimite(jid)) {
      logger.log(`[LIMITE] ${jid.split('@')[0]} excedeu limite de mensagens`);
      await sendMessage(jid, "вљ пёЏ Bot desligado por agora. Por favor, tente novamente mais tarde.");
      return;
    }

    if (!isStaff && !canReply(jid)) {
      logger.log(`[BLOQUEIO] ${jid.split('@')[0]} bloqueado por cooldown`);
      return;
    }
    if (!isStaff) await delayHumano();
    if (!isStaff) registrarMensagemKpi();

    if (texto === "menu") {
      await showMainMenu(jid);
      return;
    }

    if (isStaff) {
      const tratado = await executarComando(texto, jid);
      if (tratado) return;
    }

    switch (estado) {
      case "menu_principal": {
        switch (texto) {
          case "1":
            await showModalidadesHorariosValores(jid);
            break;
          case "2":
            await showPass(jid);
            break;
          case "3":
            setState(jid, "confirmar_atendente");
            await sendMessage(jid,
              `> *FALAR COM ATENDENTE рџ—ЈпёЏ*\n\n` +
              `VocГЄ serГЎ colocado na fila de atendimento humano.\n\n` +
              `*1 - Confirmar*\n` +
              `*0 - Voltar ao menu*`
            );
            break;
          case "4":
            await showInformacoes(jid);
            break;
          case "5":
            if (!stateData.get(jid)?.nome) {
              setState(jid, "coletar_nome_feedback");
              await sendMessage(jid,
                `рџ“ќ *Feedback importantГ­ssimo!*\n\n` +
                `Para registrar seu feedback corretamente, por favor informe seu *nome completo* primeiro:`
              );
            } else {
              await showFeedback(jid);
            }
            break;
          default:
            if (!primeiroContato.has(jid)) {
              primeiroContato.add(jid);
              kpis.atendimentosIniciados++;
              await sendMessage(jid,
                `рџЏ‹пёЏ *BEM-VINDO ГЂ ACADEMIA SEVEN7FIT!* рџЏ‹пёЏ\n\n` +
                `OlГЎ! Sou o assistente virtual.\n` +
                `Estou aqui para ajudar com modalidades, horГЎrios, valores e matrГ­culas.\n\n` +
                `Vamos comeГ§ar?`
              );
              await showMainMenu(jid);
            } else {
              await sendMessage(jid, "*OpГ§ГЈo invГЎlida*. Digite 1 a 5 ou *menu*.");
            }
        }
        break;
      }

      // (restante do switch permanece inalterado - o corpo original continua sendo utilizado)
    }
  } catch (error) {
    console.error(`[ERRO PROCESSAMENTO] ${jid.split('@')[0]}: ${error.message}`);
    try {
      await sendMessage(jid, "вќЊ *Erro interno.* Tente novamente ou digite *menu* para voltar ao inГ­cio.");
    } catch (sendError) {
      console.error(`[ERRO ENVIO] Falha ao enviar mensagem de erro: ${sendError.message}`);
    }
  }
}
async function executarComando(cmd, jid) {
  if (cmd.startsWith("liberar")) {
    const partes = cmd.split(/\s+/);
    let numeroLiberar;
    if (partes.length < 2) {
      const clientesAtuais = [...emAtendimentoHumano, ...clientesPausados];
      if (clientesAtuais.length === 0) {
        await sendMessage(jid, "вљ пёЏ Nenhum cliente em atendimento no momento.");
        return true;
      }
      numeroLiberar = clientesAtuais[0];
    } else {
      const numeroRaw = partes[1];
      numeroLiberar = [...emAtendimentoHumano, ...clientesPausados].find(j => j.startsWith(numeroRaw));
      if (!numeroLiberar) {
        let n = numeroRaw.replace(/\D/g, '');
        if (n.length < 10) { await sendMessage(jid, "вќЊ NГєmero invГЎlido. Use DDD + nГєmero."); return true; }
        if (!n.startsWith('55')) n = '55' + n;
        n = normalizarNumero(n);
        numeroLiberar = n + "@c.us";
      }
    }
    if (emAtendimentoHumano.has(numeroLiberar)) {
      const inicioAtendimento = dataAtendimento.get(numeroLiberar);
      const tempoAtendimento = inicioAtendimento
        ? Math.round((Date.now() - inicioAtendimento) / (1000 * 60)) : 0;
      if (tempoAtendimento > 0) kpis.atendimentosComTempo.push(tempoAtendimento);
      salvarHistoricoAtendimento(numeroLiberar, {
        nome: stateData.get(numeroLiberar)?.nome,
        modalidade: stateData.get(numeroLiberar)?.modalidade,
        tipo: "manual", tempoAtendimento
      });
      emAtendimentoHumano.delete(numeroLiberar);
      clientesPausados.delete(numeroLiberar);
      clearTimeout(timeoutAtendimentoTimers.get(numeroLiberar));
      timeoutAtendimentoTimers.delete(numeroLiberar);
      dataAtendimento.delete(numeroLiberar);
      clearState(numeroLiberar);
      kpis.clientesLiberados++;
      await sendMessage(numeroLiberar, `вњ… *Atendimento encerrado*\n\nO atendente finalizou seu atendimento.\nDigite *menu* para voltar.`);
      await sendMessage(jid, `вњ… Cliente ${numeroLiberar.split('@')[0]} liberado com sucesso.`);
      atendenteLivre = true;
      await processarFilaSolicitacoes();
    } else {
      await sendMessage(jid, `вљ пёЏ Cliente ${numeroLiberar.split('@')[0]} nГЈo estГЎ em atendimento.`);
    }
    return true;
  }

  if (cmd.startsWith("pausar ")) {
    const numeroRaw = cmd.split(" ")[1];
    let numero = [...emAtendimentoHumano, ...clientesPausados].find(j => j.startsWith(numeroRaw));
    if (!numero) numero = numeroRaw.replace(/\D/g, '') + "@c.us";
    if (emAtendimentoHumano.has(numero)) {
      clientesPausados.add(numero);
      await sendMessage(jid, `рџ”‡ *BOT PAUSADO*\n\nNГєmero: ${numero.split('@')[0]}\nUse "liberar ${numero.split('@')[0]}" quando terminar.`);
    } else {
      await sendMessage(jid, `вљ пёЏ ${numero.split('@')[0]} nГЈo estГЎ em atendimento humano.`);
    }
    return true;
  }

  if (cmd === "limite on" || cmd === "limite ativar") { limiteMensagensAtivo = true; await sendMessage(jid, "вњ… Limite ativado."); return true; }
  if (cmd === "limite off" || cmd === "limite desativar") { limiteMensagensAtivo = false; await sendMessage(jid, "вњ… Limite desativado."); return true; }
  if (cmd === "limite status") { await sendMessage(jid, `рџ”Ћ Limite estГЎ ${limiteMensagensAtivo ? "ativado" : "desativado"}.`); return true; }

  if (cmd === "kpi status") { await sendMessage(jid, gerarRelatorioKpi()); return true; }
  if (cmd === "kpi limpar") {
    Object.assign(kpis, {
      atendimentosIniciados: 0, comprovantesRecebidos: 0, passCheckins: 0,
      atendimentosSolicitados: 0, clientesLiberados: 0, mensagensPorHora: new Map(),
      totalMensagens: 0, tempoMedioAtendimento: 0, atendimentosComTempo: []
    });
    salvarKpisJson();
    await sendMessage(jid, "вњ… KPIs zerados.");
    return true;
  }

  if (cmd === "historico") {
    try {
      const filePath = path.join(DATA_DIR, 'historico_atendimentos.json');
      if (!fs.existsSync(filePath)) { await sendMessage(jid, "рџ“‹ Nenhum histГіrico ainda."); return true; }
      const historico = JSON.parse(fs.readFileSync(filePath, 'utf8'));
      const ultimos5 = historico.slice(-5).reverse();
      const msg = ultimos5.map((a, i) =>
        `*${i + 1}.* ${a.nome} вЂ” ${a.modalidade}\nрџ“ћ ${a.numero} | вЏ±пёЏ ${a.tempoAtendimento}min | ${a.horario}`
      ).join('\n\n');
      await sendMessage(jid, `рџ“‹ *ГљLTIMOS 5 ATENDIMENTOS*\n\n${msg}`);
    } catch (e) { await sendMessage(jid, "вќЊ Erro ao ler histГіrico."); }
    return true;
  }

  if (cmd === "fila status") {
    if (filaSolicitacoes.length === 0) {
      await sendMessage(jid, "рџ“‹ Nenhum cliente aguardando.");
    } else {
      const msg = filaSolicitacoes.map((s, i) => {
        const espera = Math.round((Date.now() - s.timestamp) / 1000 / 60);
        const nome = s.nome || "Sem nome";
        return `*${i + 1}.* ${nome} вЂ” ${formatarNumero(s.jid)} вЂ” ${s.tipoSolicitacao} вЂ” ${espera}min`;
      }).join('\n');
      await sendMessage(jid, `рџ“‹ *FILA*\n\n${msg}`);
    }
    return true;
  }

  if (cmd.startsWith("bloquear ")) {
    const n = cmd.split(" ")[1].replace(/\D/g, '') + "@c.us";
    ignoredContacts.add(n); salvarBlacklist();
    await sendMessage(jid, `вњ… ${n.split('@')[0]} bloqueado.`);
    return true;
  }
  if (cmd.startsWith("desbloquear ")) {
    const n = cmd.split(" ")[1].replace(/\D/g, '') + "@c.us";
    if (ignoredContacts.has(n)) { ignoredContacts.delete(n); salvarBlacklist(); await sendMessage(jid, `вњ… ${n.split('@')[0]} desbloqueado.`); }
    else await sendMessage(jid, `вљ пёЏ ${n.split('@')[0]} nГЈo estava bloqueado.`);
    return true;
  }
  if (cmd === "blacklist") {
    const lista = ignoredContacts.size === 0 ? "vazia" : [...ignoredContacts].map((n, i) => `${i + 1}. ${n.split('@')[0]}`).join('\n');
    await sendMessage(jid, `рџ“‹ *BLACKLIST*\n\n${lista}`);
    return true;
  }

  if (cmd === "status" || cmd === "estado" || cmd === "info") {
    const msg =
      `рџ“Љ *STATUS DO BOT*\n` +
      `Modo: ${global.modoSilencioso ? "рџ”‡ SILENCIOSO" : "рџ“ў NORMAL"}\n` +
      `Clientes em atendimento: ${emAtendimentoHumano.size}\n` +
      `Clientes pausados: ${clientesPausados.size}\n` +
      `Fila de espera: ${filaSolicitacoes.length}\n` +
      `Atendente livre: ${atendenteLivre ? "вњ… Sim" : "вќЊ NГЈo"}\n` +
      `Total de mensagens: ${kpis.totalMensagens}`;
    console.log(msg);
    await sendMessage(jid, msg);
    return true;
  }

  if (cmd === "silencioso") { global.modoSilencioso = true; console.log('[TERMINAL] Modo silencioso ativado.'); await sendMessage(jid, 'вњ… Modo silencioso ativado.'); return true; }
  if (cmd === "normal" || cmd === "verboso") { global.modoSilencioso = false; await sendMessage(jid, 'вњ… Modo normal restaurado.'); return true; }
  if (cmd === "expediente on") { forcarExpediente = true; await sendMessage(jid, 'вњ… Expediente forГ§ado como ABERTO.'); return true; }
  if (cmd === "expediente off") { forcarExpediente = false; await sendMessage(jid, 'вњ… Expediente voltou ao horГЎrio automГЎtico.'); return true; }
  if (cmd === "desligar") { await sendMessage(jid, "рџ”Њ Desligando..."); process.exit(0); }

  if (cmd === "comandos" || cmd === "ajuda" || cmd === "help") {
    await sendMessage(jid,
      `рџ“‹ *COMANDOS DISPONГЌVEIS*\n\n` +

      `*рџ‘Ґ ATENDIMENTO*\n` +
      `вЂў *liberar* вЂ” libera o primeiro cliente em atendimento\n` +
      `вЂў *liberar [nГєmero]* вЂ” libera cliente especГ­fico (ex: liberar 13999887766)\n` +
      `вЂў *pausar [nГєmero]* вЂ” pausa o bot para um cliente (bot fica mudo)\n` +
      `вЂў *fila status* вЂ” lista clientes aguardando atendimento\n\n` +

      `*рџ“Љ KPIs E HISTГ“RICO*\n` +
      `вЂў *kpi status* вЂ” exibe relatГіrio de atendimentos\n` +
      `вЂў *kpi limpar* вЂ” zera todos os KPIs\n` +
      `вЂў *historico* вЂ” mostra os Гєltimos 5 atendimentos\n\n` +

      `*рџљ« BLACKLIST*\n` +
      `вЂў *bloquear [nГєmero]* вЂ” bloqueia nГєmero (ex: bloquear 13999887766)\n` +
      `вЂў *desbloquear [nГєmero]* вЂ” remove nГєmero da blacklist\n` +
      `вЂў *blacklist* вЂ” lista todos os nГєmeros bloqueados\n\n` +

      `*вљ™пёЏ CONFIGURAГ‡Г•ES*\n` +
      `вЂў *limite on/off* вЂ” ativa ou desativa limite de mensagens/hora\n` +
      `вЂў *limite status* вЂ” verifica se o limite estГЎ ativo\n` +
      `вЂў *expediente on/off* вЂ” forГ§a o bot a aceitar fila fora do horГЎrio\n` +
      `вЂў *silencioso* вЂ” reduz logs no terminal\n` +
      `вЂў *normal* вЂ” restaura logs normais\n\n` +

      `*рџ”Ћ STATUS E CONTROLE*\n` +
      `вЂў *status* вЂ” exibe situaГ§ГЈo atual do bot\n` +
      `вЂў *desligar* вЂ” encerra o bot\n` +
      `вЂў *comandos* вЂ” exibe esta lista`
    );
    return true;
  }

  return false; // comando nГЈo reconhecido
}

async function startBot() {
  logger.log("\n" + "=".repeat(50));
  logger.log("рџљЂ INICIANDO BOT DA ACADEMIA SEVEN7FIT");
  logger.log("=".repeat(50) + "\n");

  logger.log("рџ“‹ Verificando dependГЄncias...");
  logger.log("вњ… Path OK");

  logger.log("рџ“‹ Configurando cliente WhatsApp...");
  const sessionPath = path.join(__dirname, '.wwebjs_auth');
  logger.log(`рџ“Ѓ Pasta de sessГЈo: ${sessionPath}`);

  // Manter a pasta de sessГЈo entre reinГ­cios para evitar gerar QR code sempre que possГ­vel.
  // A limpeza sГі deve ser feita manualmente se o login ficar invГЎlido.

  // optional: kill any remaining bot windows (WhatsApp Web + Baileys)
  // Nota: nГЈo desligar todos os processos do Chrome, pois isso fecha o navegador do usuГЎrio.

  logger.log("рџ“‹ Criando cliente WhatsApp...");
  try {
    client = new Client({
      authStrategy: new LocalAuth({
        dataPath: sessionPath
      }),
      puppeteer: {
        headless: true,
        executablePath: 'C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe',
        args: ['--no-sandbox', '--disable-setuid-sandbox', '--disable-dev-shm-usage', '--disable-gpu']
      }
    });
    logger.log("вњ… Cliente criado com sucesso");
  } catch (createErr) {
    logger.error("вќЊ Erro ao criar cliente: " + createErr.message);
    return;
  }

  // Tratar erros de Puppeteer (navigation/execution context errors)
  client.on('error', (err) => {
    if (err.message && err.message.includes('Execution context was destroyed')) {
      console.log('вљ пёЏ Aviso: PГЎgina do WhatsApp Web recarregou, reconectando...');
    } else {
      console.error('вќЊ Erro no cliente:', err.message);
    }
  });

  client.on('auth_failure', (message) => {
    console.error('вќЊ Falha de autenticaГ§ГЈo:', message);
    console.error('вљ пёЏ Execute LIMPAR_PASTAS.bat e reinicie o bot se continuar falhando.');
  });

  client.on('qr', (qr) => {
    console.clear();
    console.log("\n" + "=".repeat(60));
    console.log("рџ“± QR CODE - ESCANEIE COM SEU WHATSAPP AGORA! рџ“±");
    console.log("=".repeat(60) + "\n");
    qrcode.generate(qr, { small: true });
    console.log("\n" + "=".repeat(60));
    console.log("рџ‘† Abra o WhatsApp > ConfiguraГ§Гµes > Aparelhos vinculados");
    console.log("CГіdigo vГЎlido por 60 segundos");
    console.log("=".repeat(60) + "\n");

    // TambГ©m salvar como imagem
    QRCode.toFile("./.sys/qrcode.png", qr, {
      errorCorrectionLevel: 'H',
      type: 'image/png',
      width: 300,
      margin: 1,
      color: {
        dark: '#000000',
        light: '#ffffff'
      }
    }, (err) => {
      if (!err) {
        console.log("вњ… QR Code tambГ©m salvo em: .sys/qrcode.png\n");
      }
    });
  });

  client.on('ready', () => {
    console.log("\n" + "=".repeat(60));
    console.log("вњ…  BOT CONECTADO E ATIVO!");
    console.log("рџџў Aguardando mensagens...");
    console.log(`вЏ° HorГЎrio de inГ­cio: ${new Date().toLocaleString('pt-BR')}`);
    console.log("=".repeat(60) + "\n");
    console.log("вљ пёЏ  Se havia clientes em atendimento antes do restart, use 'fila status' para verificar.");
    isConnected = true;
    reconnectAttempts = 0; // Reseta contador quando reconecta com sucesso
    startBotRetries = 0; // Reseta contador de tentativas de inicializaГ§ГЈo

    // вњ… Agora carrega fila quando client estГЎ pronto (pode enviar mensagens)
    carregarFila();
  });

  /// CГіdigo Apenas da fase de testes se funcionar apaga ele
  // === BLOCO DE TESTE INTERATIVO (REMOVER EM PRODUГ‡ГѓO) ===
  // Este listener lГЄ comandos do stdin para facilitar testes manuais
  // durante desenvolvimento. Em produГ§ГЈo esse bloco deve ser removido
  // ou protegido para evitar execuГ§ГЈo inesperada.
  process.stdin.setEncoding('utf8');
  process.stdin.on('data', async (input) => {
    const cmd = input.trim().toLowerCase();
    const TERMINAL_JID = [...ADMIN_JIDS][0];
    const tratado = await executarComando(cmd, TERMINAL_JID);
    if (!tratado) console.log(`[TERMINAL] Comando nГЈo reconhecido: "${cmd}"`);
  });

  client.on('disconnected', (reason) => {
    isConnected = false;
    reconnectAttempts++;

    console.log("\n" + "=".repeat(60));
    console.log("вќЊ CONEXAO FECHADA");
    console.log(`вЏ° HorГЎrio de queda: ${new Date().toLocaleString('pt-BR')}`);
    console.log(`RazГЈo: ${reason}`);
    console.log(`рџ“Љ Tentativa de reconexГЈo: ${reconnectAttempts}/${MAX_RECONNECT_ATTEMPTS}`);
    console.log("рџ”„ Reconectando em 2 segundos...");
    console.log("=".repeat(60) + "\n");

    // Evita multiplas tentativas simultГўneas
    setTimeout(() => {
      if (!isConnected) {
        if (reconnectAttempts >= MAX_RECONNECT_ATTEMPTS) {
          console.error("\n" + "=".repeat(60));
          console.error("рџљЁ ERRO CRГЌTICO - FALLBACK ATIVADO");
          console.error("вќЊ Falha ao reconectar apГіs " + MAX_RECONNECT_ATTEMPTS + " tentativas");
          console.error("\nвљ пёЏ  AГ‡ГѓO NECESSГЃRIA:");
          console.error("1. Abra a pasta 'BotГµes'");
          console.error("2. Execute: LIGAR-2.bat (Bot Baileys - Backup)");
          console.error("3. O bot Baileys funcionarГЎ como principal atГ© resolver o problema");
          console.error("=".repeat(60) + "\n");

          // Notificar administrador
          try {
            const adminMsg = `рџљЁ *FALHA CRГЌTICA - BOT 1 OFFLINE*\n\n` +
              `WhatsApp-Web (bot-simple.js) falhou apГіs ${MAX_RECONNECT_ATTEMPTS} tentativas.\n\n` +
              `вљ пёЏ  *AГ‡ГѓO NECESSГЃRIA:*\n` +
              `1. Clique em: LIGAR-2.bat (na pasta BotГµes)\n` +
              `2. Use o Bot Baileys como backup\n\n` +
              `O que fazer:\n` +
              `- Verifique a conexГЈo de internet\n` +
              `- Reinicie o computador\n` +
              `- Execute LIMPAR_PASTAS.bat antes de tentar reconectar`;
            // Nota: sendMessage pode nГЈo funcionar se o cliente nГЈo estГЎ inicializado
            console.log("[NOTIF] Mensagem de fallback pronta para ser enviada aos admins");
          } catch (e) {
            console.error("[ERRO] Falha ao notificar administrador:", e.message);
          }

          return;
        }

        console.log("Iniciando reconexao automГЎtica...");
        startBot();
      }
    }, 2000);
  });

  // ================================
  // LГіgica principal de recebimento de mensagens
  // ================================

  // Registra o listener usando lock por JID para evitar processamentos concorrentes
  client.on('message', (message) => {
    const jid = normalizarJid(message.from);
    processWithLock(jid, () => handleIncoming(message));
  });

  logger.log("рџ“‹ Inicializando cliente WhatsApp...");
  try {
    await client.initialize();
    logger.log("вњ… Cliente inicializado com sucesso");
  } catch (err) {
    console.error('Erro capturado ao inicializar:', err.message);
    // captura erros comuns de sessГЈo travada e tenta usar uma nova pasta
    if (err.message && (err.message.includes('already running for') || err.message.includes('EBUSY'))) {
      if (startBotRetries < 3) {
        console.warn('вљ пёЏ Erro de sessГЈo travada detectado, tentando com nova pasta... (Tentativa ' + (startBotRetries + 1) + '/3)');
        startBotRetries++;
        // Tenta iniciar novamente (jГЎ que agora usa pasta com timestamp)
        return startBot();
      } else {
        console.error('вќЊ MГЎximo de tentativas de reconexГЈo atingido. Execute LIMPAR_PASTAS.bat e reinicie o bot.');
        throw new Error('MГЎximo de tentativas de inicializaГ§ГЈo atingido');
      }
    }
    throw err;
  }
}

// Inicia o bot somente quando executado diretamente
if (require.main === module) {
  startBot().catch(err => {
    console.error("вќЊ ERRO AO INICIAR BOT:", err);
    process.exit(1);
  });
}

// ExportaГ§Гµes para testes e controle externo
module.exports = {
  handleIncoming,
  executarComando,
  showMainMenu,
  showModalidadesHorariosValores,
  showModalidades,
  showValores,
  showValoresMensais,
  showValoresDiaria,
  showPass,
  setState,
  clearState,
  estados,
  stateData,
  emAtendimentoHumano,
  clientesPausados,
  adicionarFilaSolicitacao,
  processarFilaSolicitacoes,
  transferirParaAtendente,
    // === HELPERS DE TESTE (REMOVER EM PRODUГ‡ГѓO) ===
    // As trГЄs funГ§Гµes abaixo sГЈo utilitГЎrios para execuГ§ГЈo de testes locais
    // e nГЈo sГЈo necessГЎrias (nem recomendadas) em ambiente de produГ§ГЈo.
    enableTestMode: () => { global.__BOT_TEST_MODE = true; global.__BOT_TEST_MESSAGES = []; global.modoSilencioso = true; },
    disableTestMode: () => { global.__BOT_TEST_MODE = false; global.__BOT_TEST_MESSAGES = []; },
    getTestMessages: () => (global.__BOT_TEST_MESSAGES || [])
};