const fs = require('fs');
const path = require('path');
const qrcode = require('qrcode-terminal');
const QRCode = require('qrcode');
const { Client, LocalAuth } = require('whatsapp-web.js');

const DATA_DIR = path.join(__dirname, '.sys_data');
if (!fs.existsSync(DATA_DIR)) {
  fs.mkdirSync(DATA_DIR, { recursive: true });
}

const CONTATO_SUPORTE = new Set(["5513996817481@s.whatsapp.net"]);
const ADMIN_JIDS = new Set(["5513996817481@s.whatsapp.net", "5513991808686@s.whatsapp.net"]);
const ATENDENTE_ATUAL = new Set(["5513996817481@s.whatsapp.net"]);
const TEST_MODE_IGNORAR_SALVOS = false;
const LOG_MENSAGENS = false;
const AUTO_REPLY_COOLDOWN = 3000;
const STATE_TTL = 2 * 60 * 1000;
const INATIVIDADE_TTL = 2 * 60 * 1000;
const TIMEOUT_ATENDIMENTO = 30 * 60 * 1000;
const MAX_TENTATIVAS = 3;
const MAX_RECONNECT_ATTEMPTS = 5;
const LIMITE_MENSAGENS_POR_HORA = 30;
const LIMITE_WINDOW_MS = 60 * 60 * 1000;

let client = null;
let isConnected = false;
let startBotRetries = 0;
let reconnectAttempts = 0;
let atendenteLivre = true;
let limiteMensagensAtivo = true;
global.modoSilencioso = false;

const estados = new Map();
const stateData = new Map();
const timers = new Map();
const inactivityTimers = new Map();
const timeoutAtendimentoTimers = new Map();
const lastReply = new Map();
const emAtendimentoHumano = new Set();
const clientesPausados = new Set();
const clientesEmFila = new Set();
const primeiroContato = new Set();
const dataAtendimento = new Map();
const messageTimestamps = new Map();
const ignoredContacts = new Set();
const filaSolicitacoes = [];
const prioridadeTipos = { comprovante: 0, pass: 1, atendimento: 2 };

const kpis = {
  atendimentosIniciados: 0,
  comprovantesRecebidos: 0,
  passCheckins: 0,
  atendimentosSolicitados: 0,
  clientesLiberados: 0,
  limitesAtingidos: 0,
  mensagensPorHora: new Map(),
  totalMensagens: 0,
  tempoMedioAtendimento: 0,
  atendimentosComTempo: []
};

const delayHumano = () => new Promise(resolve => setTimeout(resolve, Math.random() * 3500 + 1500));

function canReply(jid) {
  const now = Date.now();
  const last = lastReply.get(jid) || 0;
  if (now - last < AUTO_REPLY_COOLDOWN) return false;
  lastReply.set(jid, now);
  return true;
}

function registrarMensagemKpi() {
  const hora = new Date().getHours();
  kpis.mensagensPorHora.set(hora, (kpis.mensagensPorHora.get(hora) || 0) + 1);
}

async function verificarLimite(jid) {
  if (!limiteMensagensAtivo) return false;
  const now = Date.now();
  const fila = (messageTimestamps.get(jid) || []).filter(ts => now - ts < LIMITE_WINDOW_MS);
  fila.push(now);
  messageTimestamps.set(jid, fila);
  if (fila.length > LIMITE_MENSAGENS_POR_HORA) {
    kpis.limitesAtingidos++;
    return true;
  }
  return false;
}

const logger = {
  log: (...args) => {
    if (!global.modoSilencioso) console.log(...args);
    try {
      fs.appendFileSync(path.join(DATA_DIR, 'bot.log'), `[LOG ${new Date().toISOString()}] ${args.join(' ')}\n`);
    } catch (_) {}
  },
  warn: (...args) => {
    console.warn(...args);
    try {
      fs.appendFileSync(path.join(DATA_DIR, 'bot.log'), `[WARN ${new Date().toISOString()}] ${args.join(' ')}\n`);
    } catch (_) {}
  },
  error: (...args) => {
    console.error(...args);
    try {
      fs.appendFileSync(path.join(DATA_DIR, 'bot.log'), `[ERROR ${new Date().toISOString()}] ${args.join(' ')}\n`);
    } catch (_) {}
  }
};

const processingLocks = new Map();
async function processWithLock(jid, fn) {
  const previous = processingLocks.get(jid) || Promise.resolve();
  const next = previous.then(() => fn()).catch((err) => {
    throw err;
  });
  processingLocks.set(jid, next.finally(() => {
    if (processingLocks.get(jid) === next) {
      processingLocks.delete(jid);
    }
  }));
  return next;
}

function normalizarJid(jid) {
  if (!jid) return jid;
  if (jid.endsWith('@lid')) return jid;
  const parts = jid.split('@');
  let numero = parts[0].replace(/\D/g, '');
  let sufixo = parts[1] || 's.whatsapp.net';
  if (numero.length === 12 && numero.startsWith('55')) {
    numero = `${numero.slice(0, 4)}9${numero.slice(4)}`;
  }
  if (numero.length === 11 && !numero.startsWith('55')) {
    numero = `55${numero}`;
  }
  if (sufixo === 'c.us') sufixo = 's.whatsapp.net';
  return `${numero}@${sufixo}`;
}

function normalizarNumero(numero) {
  if (!numero) return numero;
  const n = numero.replace(/\D/g, '');
  if (n.length === 13 && n.startsWith('55')) return n;
  if (n.length === 12 && n.startsWith('55')) return `${n.slice(0, 4)}9${n.slice(4)}`;
  if (n.length === 11 && !n.startsWith('55')) return `55${n}`;
  return n;
}

function formatarNumero(jid) {
  if (!jid) return jid;
  const numero = jid.split('@')[0].replace(/\D/g, '');
  if (!numero) return jid;
  return `+${numero}`;
}

function gerarTicketCurto(jid) {
  const base = jid.split('@')[0].replace(/\D/g, '');
  return `T-${base.slice(-4)}-${Date.now().toString().slice(-4)}`;
}

function mensagemForaExpediente() {
  return 'вљ пёЏ No momento estamos fora do horГЎrio de atendimento. Por favor, tente novamente durante o expediente.';
}

let forcarExpediente = false;
function estaNoExpediente() {
  if (forcarExpediente) return true;
  const hora = new Date().getHours();
  return hora >= 8 && hora <= 22;
}

function salvarFila() {
  try {
    fs.writeFileSync(path.join(DATA_DIR, 'fila_solicitacoes.json'), JSON.stringify(filaSolicitacoes, null, 2), 'utf8');
  } catch (_) {}
}

function carregarFila() {
  try {
    const filePath = path.join(DATA_DIR, 'fila_solicitacoes.json');
    if (fs.existsSync(filePath)) {
      const data = JSON.parse(fs.readFileSync(filePath, 'utf8'));
      filaSolicitacoes.length = 0;
      for (const item of data) filaSolicitacoes.push(item);
    }
  } catch (_) {}
}

function salvarHistoricoAtendimento(jid, dados) {
  try {
    const filePath = path.join(DATA_DIR, 'historico_atendimentos.json');
    const historico = fs.existsSync(filePath) ? JSON.parse(fs.readFileSync(filePath, 'utf8')) : [];
    historico.push({ ...dados, numero: jid.split('@')[0], horario: new Date().toLocaleString('pt-BR') });
    fs.writeFileSync(filePath, JSON.stringify(historico, null, 2), 'utf8');
  } catch (_) {}
}

function salvarKpisJson() {
  try {
    const kpisJson = { ...kpis, mensagensPorHora: Object.fromEntries(kpis.mensagensPorHora) };
    fs.writeFileSync(path.join(DATA_DIR, 'kpis.json'), JSON.stringify(kpisJson, null, 2), 'utf8');
  } catch (_) {}
}

function salvarBlacklist() {
  try {
    fs.writeFileSync(path.join(DATA_DIR, 'blacklist.json'), JSON.stringify([...ignoredContacts], null, 2), 'utf8');
  } catch (_) {}
}

async function sendMessage(jid, text, tentativa = 1) {
  try {
    if (!client) throw new Error('Cliente WhatsApp nГЈo inicializado');
    await client.sendMessage(jid, text);
    return;
  } catch (err) {
    const fallback = err?.message?.includes('No LID');
    if (fallback) {
      logger.warn(`[ERRO ENVIO] ${jid}: No LID (todos os fallbacks falharam)`);
      if (tentativa >= MAX_TENTATIVAS) {
        logger.error(`[ERRO ENVIO] ${jid}: ${err.message} (apГіs ${MAX_TENTATIVAS} tentativas)`);
        return;
      }
    }
    if (tentativa < MAX_TENTATIVAS) {
      const delay = Math.pow(2, tentativa) * 1000;
      console.warn(`[RETRY] ${jid.split('@')[0]} tentativa ${tentativa}/${MAX_TENTATIVAS} em ${delay}ms`);
      await new Promise(r => setTimeout(r, delay));
      return sendMessage(jid, text, tentativa + 1);
    }
    logger.error(`[ERRO ENVIO] ${jid}: ${err.message} (apГіs ${MAX_TENTATIVAS} tentativas)`);
  }
}

// Gerencia estados e dados temporГЎrios do usuГЎrio, com expiraГ§ГЈo automГЎtica
// customInactivity permite sobrescrever o tempo de inatividade por chamada
function setState(jid, state, data = null, customInactivity = null) {
  clearTimeout(timers.get(jid));
  clearTimeout(inactivityTimers.get(jid));
  estados.set(jid, state);
  if (data !== null) {
    stateData.set(jid, data);
    if (LOG_MENSAGENS) console.log(`[DADOS] ${jid.split('@')[0]} в†’`, data);
  } else if (state !== "pagamentos") {
    stateData.delete(jid);
  }
  if (!global.modoSilencioso) console.log(`[ESTADO] ${jid.split('@')[0]} в†’ ${state}`);
  timers.set(jid, setTimeout(() => {
    estados.delete(jid);
    stateData.delete(jid);
  }, STATE_TTL));
  // 6 min durante pagamento, 2 min nos demais
  const inactivityTime = customInactivity ||
    (state === "pagamentos" ? 6 * 60 * 1000 : INATIVIDADE_TTL);

  // Configura timer de inatividade
  inactivityTimers.set(jid, setTimeout(async () => {
    // NUNCA dispara inatividade se o cliente estiver pausado ou em atendimento humano
    if (clientesPausados.has(jid) || emAtendimentoHumano.has(jid) || clientesEmFila.has(jid)) {
      return;
    }

    if (estados.get(jid) !== "menu_principal") {
      const currentData = stateData.get(jid) || {};
      currentData.previousState = estados.get(jid);
      stateData.set(jid, currentData);
      estados.set(jid, "inativo");
      await sendMessage(jid, "вЏ° Inatividade detectada. Deseja continuar ou voltar ao menu?\n\n*1 - Continuar*\n*0 - Voltar ao menu*");
    }
  }, inactivityTime));
}

function clearState(jid) {
  if (!jid) return;

  estados.delete(jid);
  stateData.delete(jid);

  clearTimeout(timers.get(jid));
  clearTimeout(inactivityTimers.get(jid));
  clearTimeout(timeoutAtendimentoTimers.get(jid));

  timers.delete(jid);
  inactivityTimers.delete(jid);
  timeoutAtendimentoTimers.delete(jid);

  primeiroContato.delete(jid);
  // вњ… FIX: TambГ©m limpa dataAtendimento quando limpa estado
  dataAtendimento.delete(jid);
  clientesEmFila.delete(jid);
  lastReply.delete(jid);
  messageTimestamps.delete(jid);
  // NГЈo removemos de clientesPausados aqui, pois Г© controlado pelo comando liberar
}

// ====================== TIMEOUT PARA ATENDIMENTO ======================
function configurarTimeoutAtendimento(jid) {
  // Limpar timeout anterior se existir
  clearTimeout(timeoutAtendimentoTimers.get(jid));

  const timeoutId = setTimeout(async () => {
    if (emAtendimentoHumano.has(jid)) {
      console.log(`[TIMEOUT] Cliente ${jid.split('@')[0]} foi auto-liberado apГіs 30 minutos`);

      // Calcular tempo de atendimento
      const inicioAtendimento = dataAtendimento.get(jid);
      const tempoAtendimento = inicioAtendimento ? Math.round((Date.now() - inicioAtendimento) / (1000 * 60)) : 0; // em minutos
      if (tempoAtendimento > 0) kpis.atendimentosComTempo.push(tempoAtendimento);
      // Salvar histГіrico do atendimento com tipo "timeout"
      salvarHistoricoAtendimento(jid, {
        nome: stateData.get(jid)?.nome,
        modalidade: stateData.get(jid)?.modalidade,
        tipo: "timeout",
        tempoAtendimento
      });
      // Notificar cliente
      await sendMessage(jid,
        `вЏ° *Tempo de atendimento expirado*\n\n` +
        `Seu atendimento foi encerrado automaticamente apГіs 30 minutos.\n` +
        `Digite *menu* para retornar ao menu principal ou *atendente* para nova solicitaГ§ГЈo.`);

      // Notificar atendente
      for (const atendente of ATENDENTE_ATUAL) {
        await sendMessage(atendente,
          `вЏ° *TIMEOUT DE ATENDIMENTO*\n\n` +
          `Cliente ${jid.split('@')[0]} foi auto-liberado apГіs 30 minutos.\n` +
          `${filaSolicitacoes.length} cliente(s) ainda aguardando na fila.`);
      }

      emAtendimentoHumano.delete(jid);
      dataAtendimento.delete(jid);
      timeoutAtendimentoTimers.delete(jid);
      kpis.clientesLiberados++;

      atendenteLivre = true;
      await processarFilaSolicitacoes();
    }
  }, TIMEOUT_ATENDIMENTO);

  timeoutAtendimentoTimers.set(jid, timeoutId);
}

// ====================== FILA COM PRIORIDADES ======================
async function adicionarFilaSolicitacao(jid, tipoSolicitacao, mensagemOriginal) {
  if (emAtendimentoHumano.has(jid) || clientesPausados.has(jid)) {
    await sendMessage(jid, "вљ пёЏ VocГЄ jГЎ estГЎ em atendimento. Aguarde o atendente responder.");
    return;
  }

  // Verifica se jГЎ existe na fila
  const jaNaFila = filaSolicitacoes.some(s => s.jid === jid);
  if (jaNaFila) {
    const posicao = filaSolicitacoes.findIndex(s => s.jid === jid) + 1;
    await sendMessage(jid,
      `вЏі *VocГЄ jГЎ estГЎ na fila de atendimento*\n\n` +
      `рџ“‹ PosiГ§ГЈo atual: *${posicao}Вє*\n` +
      `Aguarde o atendente te chamar.`);
    return;
  }

  const prioridade = prioridadeTipos[tipoSolicitacao] ?? 2;
  const ctxSnapshot = stateData.get(jid) || {};
  const solicitacao = {
    jid,
    tipoSolicitacao,
    mensagemOriginal,
    prioridade,
    timestamp: Date.now(),
    nome: ctxSnapshot.nome || null,
    modalidade: ctxSnapshot.modalidade || null,
    ticketId: gerarTicketCurto(jid)
  };

  // Se o cliente entrou na fila, pausa o fluxo automГЎtico anterior e evita prompts de inatividade.
  clearState(jid);
  primeiroContato.add(jid);

  filaSolicitacoes.push(solicitacao);
  clientesEmFila.add(jid);
  filaSolicitacoes.sort((a, b) => {
    if (a.prioridade === b.prioridade) {
      return a.timestamp - b.timestamp;
    }
    return a.prioridade - b.prioridade;
  });
  salvarFila();
  const posicaoFila = filaSolicitacoes.findIndex(s => s.jid === jid) + 1;
  const totalFila = filaSolicitacoes.length;

  // вњ… EVENTO: Cliente adicionado Г  fila
  logger.log(`[EVENTO] рџ“‹ CLIENTE NA FILA\n${jid.split('@')[0]} | Tipo: ${tipoSolicitacao} | PosiГ§ГЈo: ${posicaoFila}/${totalFila}\n`);

  if (!atendenteLivre || totalFila > 1) {
    await sendMessage(jid,
      `вЏі *VocГЄ estГЎ na fila de atendimento*\n\n` +
      `рџ“‹ PosiГ§ГЈo: *${posicaoFila}Вє*\n` +
      `рџ‘Ґ Total na fila: *${totalFila}*\n\n` +
      `O atendente vai te chamar em breve.\nAguarde...`);
  }

  if (atendenteLivre) {
    await processarFilaSolicitacoes();
  }
}

async function processarFilaSolicitacoes() {
  if (filaSolicitacoes.length === 0 || !atendenteLivre) return;

  atendenteLivre = false;
  const solicitacao = filaSolicitacoes.shift();
  salvarFila();
  const { jid, tipoSolicitacao } = solicitacao;
  clientesEmFila.delete(jid);
  const userCtx = {
    nome: solicitacao.nome || stateData.get(jid)?.nome || "NГЈo informado",
    modalidade: solicitacao.modalidade || stateData.get(jid)?.modalidade || "NГЈo informada"
  };
  stateData.set(jid, userCtx);

  const agora = new Date().toLocaleString('pt-BR', {
    day: '2-digit',
    month: '2-digit',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit'
  });

  let emoji = "рџ“Њ";
  let titulo = "SOLICITAГ‡ГѓO DE ASSISTГЉNCIA";

  if (tipoSolicitacao === "comprovante") {
    emoji = "рџ’°";
    titulo = "COMPROVANTE RECEBIDO";
  } else if (tipoSolicitacao === "pass") {
    emoji = "рџџ ";
    titulo = "CHECK-IN DE PASS SOLICITADO";
  } else if (tipoSolicitacao === "atendimento") {
    emoji = "рџ””";
    titulo = "SOLICITAГ‡ГѓO DE ATENDIMENTO";
  } else if (tipoSolicitacao === "assistГЄncia") {
    emoji = "рџ› пёЏ";
    titulo = "SOLICITAГ‡ГѓO DE ASSISTГЉNCIA";
  } else if (tipoSolicitacao === "feedback") {
    emoji = "в­ђ";
    titulo = "FEEDBACK RECEBIDO";
  } else if (tipoSolicitacao === "problema") {
    emoji = "вљ пёЏ";
    titulo = "PROBLEMA REPORTADO";
  }

  const clienteJid = formatarNumero(jid);
  const nomeExibir = userCtx.nome !== "NГЈo informado" ? userCtx.nome : "вљ пёЏ Nome nГЈo coletado";

  const mensagemParaAtendente =
    `${emoji} *${titulo}*\n\n` +
    `рџ“› *Nome:* ${nomeExibir}\n` +
    `рџ“ћ *NГєmero:* ${clienteJid}\n` +
    `рџЋџпёЏ *Ticket:* ${solicitacao.ticketId}\n` +
    `рџЏ·пёЏ *Tipo:* ${tipoSolicitacao}\n` +
    `рџЏ‹пёЏ *Modalidade:* ${userCtx.modalidade}\n` +
    `вЏ° *HorГЎrio:* ${agora}\n` +
    `рџ”‘ *Para liberar:* liberar ${jid.split('@')[0]}\n\n`

  try {
    // Mensagem para o cliente que acabou de ser atendido
    await sendMessage(jid,
      `вњ… *SolicitaГ§ГЈo recebida!*\n\n` +
      `Nossa equipe foi notificada e vai te atender em breve.`
    );

    // DEPOIS adiciona ao estado de atendimento
    emAtendimentoHumano.add(jid);
    dataAtendimento.set(jid, Date.now());
    configurarTimeoutAtendimento(jid);

    // DEPOIS notifica atendente (operaГ§ГЈo crГ­tica - mas jГЎ estГЎ em atendimento)
    for (const atendente of ATENDENTE_ATUAL) {
      await sendMessage(atendente, mensagemParaAtendente);
    }
    logger.log(`[NOTIF] AssistГЄncia notificada para ${ATENDENTE_ATUAL}`);
  } catch (err) {
    console.error(`[ERRO FILA] ${err.message}`);
    // вњ… FIX: Se falhar, limpa estado incompleto
    emAtendimentoHumano.delete(jid);
    dataAtendimento.delete(jid);
    clearTimeout(timeoutAtendimentoTimers.get(jid));
    timeoutAtendimentoTimers.delete(jid);
    // Volta fila para tentar de novo
    filaSolicitacoes.unshift(solicitacao);
    atendenteLivre = true;
    return;
  }

  // Notifica o prГіximo da fila restante
  if (filaSolicitacoes.length > 0) {
    const proximo = filaSolicitacoes[0];
    await sendMessage(proximo.jid,
      `рџ”” *VocГЄ Г© o prГіximo da fila!*\n\n` +
      `Fique atento вЂ” o atendente vai te chamar em instantes.`
    );

    // Atualiza a posiГ§ГЈo dos demais na fila
    for (let i = 1; i < filaSolicitacoes.length; i++) {
      const s = filaSolicitacoes[i];
      await sendMessage(s.jid,
        `рџ”„ *AtualizaГ§ГЈo da fila*\n\n` +
        `VocГЄ avanГ§ou para a posiГ§ГЈo *${i + 1}Вє*.\n` +
        `Aguarde, o atendente vai te chamar em breve.`
      );
    }
  }
  // Atualiza KPIs
  if (tipoSolicitacao === "comprovante" || tipoSolicitacao === "assistГЄncia") {
    kpis.comprovantesRecebidos++;
  } else if (tipoSolicitacao === "pass") {
    kpis.passCheckins++;
  } else if (tipoSolicitacao === "atendimento") {
    kpis.atendimentosSolicitados++;
  }
}


// ====================== TRANSFERГЉNCIA PARA ATENDENTE ======================
async function transferirParaAtendente(jid, tipoSolicitacao, mensagemOriginal) {
  if (!estaNoExpediente()) {
    await sendMessage(jid, mensagemForaExpediente());
    await showMainMenu(jid); // evita que o cliente fique preso no estado atual
    return;
  }

  const ctx = stateData.get(jid) || {};
  if (!ctx.nome && tipoSolicitacao !== "pass") {
    setState(jid, "coletar_nome_fila", { pendingTipo: tipoSolicitacao, mensagemOriginal });
    await sendMessage(jid,
      `вњ… *Quase lГЎ!*

` +
      `Para facilitar o atendimento, informe seu *nome completo*:`
    );
    return;
  }

  await adicionarFilaSolicitacao(jid, tipoSolicitacao, mensagemOriginal);
}

// ====================== ENVIO DE FEEDBACK PARA SUPORTE ======================
async function enviarFeedbackSuporte(jid, tipo, conteudo) {
  try {
    const suporteJid = [...CONTATO_SUPORTE][0]; // pega o primeiro nГєmero de suporte

    if (!suporteJid) return;

    const agora = new Date().toLocaleString('pt-BR');

    const nomeCliente = stateData.get(jid)?.nome || formatarNumero(jid);
    await sendMessage(suporteJid,
      `рџ“ќ *FEEDBACK RECEBIDO*\n\n` +
      `рџ‘¤ *Cliente:* ${nomeCliente}\n` +
      `рџ“Њ *Tipo:* ${tipo}\n` +
      `вЏ° *HorГЎrio:* ${agora}\n\n` +
      `Mensagem:\n${conteudo}`
    );
  } catch (error) {
    console.error(`[ERRO] Falha ao enviar feedback para suporte: ${error.message}`);
  }
}
// ================================
// MENUS
// ================================
async function showMainMenu(jid) {
  setState(jid, "menu_principal");
  await sendMessage(jid,
    `=================================\n` +
    `> *ACADEMIA SEVEN7FIT - MENU PRINCIPAL* рџЏ‹пёЏ\n` +
    `=================================\n\n` +
    `*ESCOLHA UMA OPCAO:*\n\n` +
    `1 - рџЏѓ Modalidades / Valores / Horarios\n` +
    `2 - рџЋ« Pass (Wellhub / TotalPass)\n` +
    `3 - рџ—ЈпёЏ Atendimento\n` +
    `4 - в„№пёЏ Informacoes\n` +
